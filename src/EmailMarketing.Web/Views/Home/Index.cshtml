@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "MailTo — Email Marketing Platform";
    var companyName = Configuration.GetSection("AppSettings")["CompanyFullName"] ?? "MailTo";
}

@section Styles {
<style>
    /* ── Reset for public pages ── */
    body { background: #fff; }

    /* ── Hero ── */
    .hero {
        background: #0d1117;
        min-height: 92vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
        padding: 80px 0 60px;
    }

    /* Dot-grid background */
    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.055) 1px, transparent 1px);
        background-size: 28px 28px;
        pointer-events: none;
    }

    /* Glow blobs */
    .hero-blob-1 {
        position: absolute;
        top: -100px;
        left: -100px;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(88,101,242,0.22) 0%, transparent 65%);
        pointer-events: none;
    }

    .hero-blob-2 {
        position: absolute;
        bottom: -80px;
        right: -50px;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(124,58,237,0.18) 0%, transparent 65%);
        pointer-events: none;
    }

    .hero-content { position: relative; z-index: 1; }

    .hero-tag {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: rgba(88,101,242,0.12);
        border: 1px solid rgba(88,101,242,0.3);
        color: #818cf8;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 5px 12px;
        border-radius: 50em;
        margin-bottom: 22px;
    }

    .hero-title {
        font-size: clamp(2.2rem, 5vw, 3.6rem);
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.04em;
        line-height: 1.1;
        margin-bottom: 20px;
    }

    .hero-title .gradient-text {
        background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #c4b5fd 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-subtitle {
        font-size: 1.05rem;
        color: #9ca3af;
        line-height: 1.7;
        max-width: 520px;
        margin-bottom: 36px;
    }

    .hero-cta-group {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
    }

    .btn-hero-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: #5865f2;
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
    }

    .btn-hero-primary:hover {
        background: #4752c4;
        color: #fff;
        box-shadow: 0 6px 20px rgba(88,101,242,0.4);
        transform: translateY(-1px);
    }

    .btn-hero-ghost {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: transparent;
        color: #9ca3af;
        font-weight: 600;
        font-size: 0.9rem;
        padding: 12px 20px;
        border-radius: 8px;
        text-decoration: none;
        border: 1px solid rgba(255,255,255,0.1);
        transition: all 0.2s;
    }

    .btn-hero-ghost:hover {
        color: #fff;
        border-color: rgba(255,255,255,0.25);
        background: rgba(255,255,255,0.05);
    }

    .hero-social-proof {
        margin-top: 44px;
        display: flex;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .proof-item {
        display: flex;
        align-items: center;
        gap: 6px;
        color: #6b7280;
        font-size: 0.8rem;
        font-weight: 500;
    }

    .proof-item i { color: #5865f2; font-size: 0.85rem; }

    /* Hero visual card */
    .hero-visual {
        position: relative;
        z-index: 1;
    }

    .hero-app-card {
        background: #161b27;
        border: 1px solid rgba(255,255,255,0.07);
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
    }

    .hero-app-card-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .hero-app-card-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }

    .hero-stat-row {
        display: grid;
        grid-template-columns: repeat(3,1fr);
        gap: 10px;
        margin-bottom: 16px;
    }

    .hero-stat {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
    }

    .hero-stat-val {
        font-size: 1.3rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.03em;
    }

    .hero-stat-label {
        font-size: 0.65rem;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 2px;
    }

    .hero-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
    }

    .hero-bar-label {
        font-size: 0.72rem;
        color: #6b7280;
        width: 60px;
        flex-shrink: 0;
    }

    .hero-bar-track {
        flex: 1;
        height: 6px;
        background: rgba(255,255,255,0.06);
        border-radius: 3px;
        overflow: hidden;
    }

    .hero-bar-fill {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg, #5865f2, #818cf8);
    }

    .hero-bar-pct {
        font-size: 0.72rem;
        color: #818cf8;
        font-weight: 700;
        width: 28px;
        text-align: right;
        flex-shrink: 0;
    }

    /* ── Stats strip ── */
    .stats-strip {
        background: #0d1117;
        padding: 40px 0;
        border-top: 1px solid rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .stat-strip-item {
        text-align: center;
        padding: 0 20px;
    }

    .stat-strip-number {
        font-size: 2rem;
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.04em;
        line-height: 1;
    }

    .stat-strip-number span { color: #818cf8; }

    .stat-strip-label {
        font-size: 0.78rem;
        color: #6b7280;
        font-weight: 500;
        margin-top: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    /* ── Section base ── */
    .section { padding: 80px 0; }
    .section-dark { background: #0d1117; }
    .section-light { background: #fff; }
    .section-muted { background: #f8fafc; }

    .section-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(88,101,242,0.08);
        color: #5865f2;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 4px 10px;
        border-radius: 50em;
        margin-bottom: 14px;
    }

    .section-title {
        font-size: clamp(1.6rem, 3vw, 2.4rem);
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.03em;
        line-height: 1.2;
        margin-bottom: 12px;
    }

    .section-title-white { color: #fff; }

    .section-subtitle {
        font-size: 1rem;
        color: #64748b;
        line-height: 1.7;
        max-width: 540px;
    }

    .section-subtitle-white { color: #9ca3af; }

    /* ── Feature cards ── */
    .feature-card {
        background: #fff;
        border: 1px solid #e8ecf1;
        border-radius: 14px;
        padding: 28px;
        height: 100%;
        transition: all 0.25s;
    }

    .feature-card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        transform: translateY(-3px);
        border-color: rgba(88,101,242,0.2);
    }

    .feature-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
        margin-bottom: 16px;
    }

    .feature-card h5 {
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
        letter-spacing: -0.02em;
        margin-bottom: 8px;
    }

    .feature-card p {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.65;
        margin: 0;
    }

    /* ── How it works ── */
    .step-card {
        text-align: center;
        padding: 0 16px;
    }

    .step-number {
        width: 52px;
        height: 52px;
        background: rgba(88,101,242,0.12);
        border: 2px solid rgba(88,101,242,0.25);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 800;
        color: #818cf8;
        margin: 0 auto 16px;
        letter-spacing: -0.02em;
    }

    .step-card h5 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 8px;
    }

    .step-card p {
        font-size: 0.82rem;
        color: #6b7280;
        line-height: 1.6;
        margin: 0;
    }

    /* step connector line */
    .steps-row { position: relative; }
    .steps-row::before {
        content: '';
        position: absolute;
        top: 26px;
        left: calc(50% / 4 + 40px);
        right: calc(50% / 4 + 40px);
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(88,101,242,0.3), rgba(88,101,242,0.3), transparent);
        pointer-events: none;
    }

    /* ── FAQ ── */
    .faq-accordion .accordion-item {
        border: 1px solid #e8ecf1;
        border-radius: 10px !important;
        margin-bottom: 8px;
        overflow: hidden;
    }

    .faq-accordion .accordion-button {
        font-weight: 600;
        font-size: 0.9rem;
        color: #0f172a;
        background: #fff;
        border-radius: 10px !important;
        box-shadow: none;
        padding: 16px 20px;
    }

    .faq-accordion .accordion-button:not(.collapsed) {
        color: #5865f2;
        background: rgba(88,101,242,0.04);
    }

    .faq-accordion .accordion-button::after {
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='%235865f2'%3e%3cpath fill-rule='evenodd' d='M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z'/%3e%3c/svg%3e");
    }

    .faq-accordion .accordion-body {
        font-size: 0.875rem;
        color: #64748b;
        line-height: 1.7;
        padding: 4px 20px 18px;
    }

    /* ── CTA section ── */
    .cta-section {
        background: linear-gradient(135deg, #0d1117 0%, #1a1f35 100%);
        padding: 80px 0;
        position: relative;
        overflow: hidden;
        text-align: center;
    }

    .cta-section::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 700px;
        height: 400px;
        background: radial-gradient(ellipse, rgba(88,101,242,0.2) 0%, transparent 65%);
        pointer-events: none;
    }

    .cta-section > * { position: relative; z-index: 1; }

    .cta-section h2 {
        font-size: clamp(1.8rem, 4vw, 2.8rem);
        font-weight: 800;
        color: #fff;
        letter-spacing: -0.04em;
        margin-bottom: 12px;
    }

    .cta-section p {
        color: #9ca3af;
        font-size: 1rem;
        margin-bottom: 32px;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }

    /* ── Footer ── */
    .public-footer {
        background: #0d1117;
        padding: 60px 0 30px;
        border-top: 1px solid rgba(255,255,255,0.06);
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
    }

    .footer-brand-icon {
        width: 32px;
        height: 32px;
        background: rgba(88,101,242,0.2);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #818cf8;
        font-size: 0.95rem;
    }

    .footer-brand-text {
        color: #fff;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: -0.02em;
    }

    .footer-tagline {
        font-size: 0.82rem;
        color: #6b7280;
        line-height: 1.6;
        max-width: 260px;
    }

    .footer-heading {
        color: #fff;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
    }

    .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .footer-links li { margin-bottom: 8px; }

    .footer-links a {
        color: #6b7280;
        font-size: 0.82rem;
        font-weight: 500;
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-links a:hover { color: #fff; }

    .footer-social {
        display: flex;
        gap: 8px;
        margin-top: 4px;
    }

    .footer-social a {
        width: 32px;
        height: 32px;
        background: rgba(255,255,255,0.06);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6b7280;
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .footer-social a:hover { background: rgba(88,101,242,0.2); color: #818cf8; }

    .footer-bottom {
        margin-top: 48px;
        padding-top: 20px;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 10px;
    }

    .footer-bottom span {
        font-size: 0.78rem;
        color: #4b5563;
    }

    /* ── Animations ── */
    .animate-on-scroll {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .animate-on-scroll.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>
}

<!-- HERO ──────────────────────────────────────── -->
<section class="hero">
    <div class="hero-blob-1"></div>
    <div class="hero-blob-2"></div>
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 hero-content">
                <div class="hero-tag">
                    <i class="bi bi-lightning-charge-fill"></i> Email Marketing Platform
                </div>
                <h1 class="hero-title">
                    Activate your entire<br>
                    <span class="gradient-text">customer experience</span>
                </h1>
                <p class="hero-subtitle">
                    Grow your audience, promote your services, and send smarter campaigns — with tools that do the heavy lifting for you.
                </p>
                <div class="hero-cta-group">
                    <a asp-controller="Account" asp-action="Register" class="btn-hero-primary">
                        <i class="bi bi-rocket-takeoff-fill"></i> Get started free
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn-hero-ghost">
                        Sign in <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="hero-social-proof">
                    <div class="proof-item">
                        <i class="bi bi-check-circle-fill"></i> No credit card required
                    </div>
                    <div class="proof-item">
                        <i class="bi bi-check-circle-fill"></i> Free trial included
                    </div>
                    <div class="proof-item">
                        <i class="bi bi-check-circle-fill"></i> Setup in minutes
                    </div>
                </div>
            </div>

            <!-- App preview card -->
            <div class="col-lg-6 hero-visual d-none d-lg-block">
                <div class="hero-app-card">
                    <div class="hero-app-card-header">
                        <div class="hero-app-card-dot" style="background:#ff5f57;"></div>
                        <div class="hero-app-card-dot" style="background:#ffbd2e;"></div>
                        <div class="hero-app-card-dot" style="background:#28ca41;"></div>
                        <span style="margin-left:8px;font-size:0.72rem;color:#4b5563;font-weight:600;">Campaign Analytics</span>
                    </div>
                    <div class="hero-stat-row">
                        <div class="hero-stat">
                            <div class="hero-stat-val">2.4k</div>
                            <div class="hero-stat-label">Delivered</div>
                        </div>
                        <div class="hero-stat">
                            <div class="hero-stat-val" style="color:#818cf8;">68%</div>
                            <div class="hero-stat-label">Open rate</div>
                        </div>
                        <div class="hero-stat">
                            <div class="hero-stat-val" style="color:#22c55e;">24%</div>
                            <div class="hero-stat-label">Clicked</div>
                        </div>
                    </div>
                    <div style="margin-bottom:14px;">
                        <div style="font-size:0.7rem;font-weight:700;color:#4b5563;letter-spacing:0.05em;text-transform:uppercase;margin-bottom:10px;">Campaign Performance</div>
                        <div class="hero-bar">
                            <div class="hero-bar-label">Welcome</div>
                            <div class="hero-bar-track"><div class="hero-bar-fill" style="width:82%;"></div></div>
                            <div class="hero-bar-pct">82%</div>
                        </div>
                        <div class="hero-bar">
                            <div class="hero-bar-label">Promo Q4</div>
                            <div class="hero-bar-track"><div class="hero-bar-fill" style="width:68%;background:linear-gradient(90deg,#7c3aed,#a78bfa);"></div></div>
                            <div class="hero-bar-pct">68%</div>
                        </div>
                        <div class="hero-bar">
                            <div class="hero-bar-label">Newsletter</div>
                            <div class="hero-bar-track"><div class="hero-bar-fill" style="width:55%;background:linear-gradient(90deg,#0ea5e9,#38bdf8);"></div></div>
                            <div class="hero-bar-pct">55%</div>
                        </div>
                    </div>
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 12px;background:rgba(88,101,242,0.1);border-radius:8px;border:1px solid rgba(88,101,242,0.2);">
                        <div style="font-size:0.75rem;color:#818cf8;font-weight:600;"><i class="bi bi-lightning-charge-fill me-1"></i>Campaign Active</div>
                        <div style="font-size:0.72rem;color:#6b7280;">Sending to 1,240 contacts…</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS STRIP ──────────────────────────────── -->
<div class="stats-strip">
    <div class="container">
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-3">
                <div class="stat-strip-item">
                    <div class="stat-strip-number">10k<span>+</span></div>
                    <div class="stat-strip-label">Emails sent</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-strip-item">
                    <div class="stat-strip-number">98<span>%</span></div>
                    <div class="stat-strip-label">Deliverability</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-strip-item">
                    <div class="stat-strip-number">500<span>+</span></div>
                    <div class="stat-strip-label">Active campaigns</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-strip-item">
                    <div class="stat-strip-number">24<span>/7</span></div>
                    <div class="stat-strip-label">Support</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FEATURES ─────────────────────────────────── -->
<section class="section section-light">
    <div class="container">
        <div class="text-center mb-5 animate-on-scroll">
            <div class="section-tag"><i class="bi bi-stars"></i> Features</div>
            <h2 class="section-title">Everything you need to grow</h2>
            <p class="section-subtitle mx-auto">
                @companyName gives you the tools to build, send, and track email campaigns — without the complexity.
            </p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-4 animate-on-scroll" style="transition-delay:0.05s">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(88,101,242,0.1);color:#5865f2;">
                        <i class="bi bi-people-fill"></i>
                    </div>
                    <h5>Contact Management</h5>
                    <p>Import thousands of contacts from Excel, organise them into groups, and keep your list clean and up-to-date.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 animate-on-scroll" style="transition-delay:0.1s">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(34,197,94,0.1);color:#16a34a;">
                        <i class="bi bi-send-fill"></i>
                    </div>
                    <h5>Bulk Email Sending</h5>
                    <p>Send personalised emails to thousands of contacts at once using your own SMTP configuration for maximum deliverability.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 animate-on-scroll" style="transition-delay:0.15s">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(245,158,11,0.1);color:#d97706;">
                        <i class="bi bi-bar-chart-line-fill"></i>
                    </div>
                    <h5>Campaign Analytics</h5>
                    <p>Track every open, click, and delivery in real time. Export detailed reports to Excel for deeper analysis.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-4 animate-on-scroll" style="transition-delay:0.2s">
                <div class="feature-card">
                    <div class="feature-icon" style="background:rgba(139,92,246,0.1);color:#7c3aed;">
                        <i class="bi bi-file-earmark-richtext-fill"></i>
                    </div>
