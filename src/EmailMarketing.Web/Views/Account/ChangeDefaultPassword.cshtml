@model ChangeDefaultPasswordViewModel
@{
    ViewData["Title"] = "Set Your Password";
    Layout = "_AccountLayout";
}

@section Styles {
<style>
    body { background: #f0f4f9; }
    .auth-card-wrap { width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 16px; }
    .auth-card { width: 100%; max-width: 440px; background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; box-shadow: 0 4px 24px rgba(0,0,0,0.07); overflow: hidden; }
    .auth-card-header { background: #0d1117; padding: 32px 36px 28px; text-align: center; position: relative; overflow: hidden; }
    .auth-card-header::before { content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%); width: 300px; height: 200px; background: radial-gradient(ellipse, rgba(34,197,94,0.2) 0%, transparent 70%); pointer-events: none; }
    .auth-card-icon { width: 54px; height: 54px; border-radius: 14px; background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); display: flex; align-items: center; justify-content: center; color: #4ade80; font-size: 1.4rem; margin: 0 auto 14px; position: relative; }
    .auth-card-title { color: #fff; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 4px; }
    .auth-card-sub { color: #6b7280; font-size: 0.82rem; margin: 0; }
    .auth-card-body { padding: 28px 36px 32px; }
    .auth-input-group { position: relative; margin-bottom: 14px; }
    .auth-input-group .form-control { height: 44px; font-size: 0.875rem; border-color: #e2e8f0; border-radius: 8px; transition: all 0.2s; padding-right: 40px; }
    .auth-input-group .form-control:focus { border-color: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,0.1); }
    .auth-input-group .toggle { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); background: none; border: none; color: #94a3b8; cursor: pointer; }
    .auth-submit-btn { width: 100%; height: 44px; background: #22c55e; border: none; border-radius: 8px; color: #fff; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px; }
    .auth-submit-btn:hover { background: #16a34a; box-shadow: 0 4px 12px rgba(34,197,94,0.35); transform: translateY(-1px); }
</style>
}

<div class="auth-card-wrap">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-card-icon"><i class="bi bi-lock-fill"></i></div>
            <div class="auth-card-title">Set your password</div>
            <p class="auth-card-sub">You're using a default password — please change it now</p>
        </div>
        <div class="auth-card-body">
            <form asp-controller="Account" asp-action="ChangeDefaultPassword" method="post" novalidate>
                <input type="hidden" asp-for="Email" />
                <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">Current (Default) Password</div>
                <div class="auth-input-group">
                    <input asp-for="OldPassword" type="password" class="form-control" placeholder="Your current password" id="op" />
                    <button type="button" class="toggle" onclick="var el=document.getElementById('op'),ic=document.getElementById('oi');var s=el.type==='password';el.type=s?'text':'password';ic.className=s?'bi bi-eye-slash':'bi bi-eye';" tabindex="-1">
                        <i class="bi bi-eye" id="oi"></i>
                    </button>
                </div>
                <span asp-validation-for="OldPassword" class="field-validation-error" style="font-size:0.78rem;display:block;margin-top:-8px;margin-bottom:10px;"></span>

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">New Password</div>
                <div class="auth-input-group">
                    <input asp-for="Password" type="password" class="form-control" placeholder="Choose a strong password" id="np" />
                    <button type="button" class="toggle" onclick="var el=document.getElementById('np'),ic=document.getElementById('ni');var s=el.type==='password';el.type=s?'text':'password';ic.className=s?'bi bi-eye-slash':'bi bi-eye';" tabindex="-1">
                        <i class="bi bi-eye" id="ni"></i>
                    </button>
                </div>
                <div style="height:4px;background:#f1f5f9;border-radius:2px;margin:-8px 0 10px;overflow:hidden;">
                    <div id="bar" style="height:100%;border-radius:2px;transition:width 0.3s,background 0.3s;width:0;background:#ef4444;"></div>
                </div>
                <span asp-validation-for="Password" class="field-validation-error" style="font-size:0.78rem;display:block;margin-bottom:10px;"></span>

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">Confirm New Password</div>
                <div class="auth-input-group">
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat your new password" id="cnp" />
                    <button type="button" class="toggle" onclick="var el=document.getElementById('cnp'),ic=document.getElementById('ci');var s=el.type==='password';el.type=s?'text':'password';ic.className=s?'bi bi-eye-slash':'bi bi-eye';" tabindex="-1">
                        <i class="bi bi-eye" id="ci"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-validation-error" style="font-size:0.78rem;display:block;margin-top:-8px;margin-bottom:14px;"></span>

                <button type="submit" class="auth-submit-btn">
                    <i class="bi bi-check-circle-fill"></i> Set New Password
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('np').addEventListener('input', function () {
            var v = this.value, bar = document.getElementById('bar'), s = 0;
            if (v.length >= 6) s++; if (v.length >= 10) s++;
            if (/[A-Z]/.test(v)) s++; if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
            bar.style.width = v ? (['20%','40%','60%','80%','100%'][s-1]||'20%') : '0';
            bar.style.background = v ? (['#ef4444','#f59e0b','#f59e0b','#22c55e','#22c55e'][s-1]||'#ef4444') : '#ef4444';
        });
    </script>
}
