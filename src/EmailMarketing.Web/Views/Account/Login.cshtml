@model LoginModel

@{
    ViewData["Title"] = "Sign In";
    Layout = "_AccountLayout";
}

@section Styles {
<style>
    body { background: #f0f4f9; }

    .auth-wrapper {
        min-height: 100vh;
        display: flex;
    }

    /* ── Left panel ── */
    .auth-panel {
        width: 420px;
        flex-shrink: 0;
        background: #0d1117;
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 48px 44px;
        overflow: hidden;
    }

    .auth-panel::before {
        content: '';
        position: absolute;
        top: -120px;
        left: -80px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(88,101,242,0.35) 0%, transparent 70%);
        pointer-events: none;
    }

    .auth-panel::after {
        content: '';
        position: absolute;
        bottom: -80px;
        right: -60px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(124,58,237,0.25) 0%, transparent 70%);
        pointer-events: none;
    }

    .auth-panel-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: auto;
        position: relative;
        z-index: 1;
    }

    .auth-panel-logo-icon {
        width: 38px;
        height: 38px;
        background: rgba(88,101,242,0.2);
        border: 1px solid rgba(88,101,242,0.4);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #818cf8;
        font-size: 1.1rem;
    }

    .auth-panel-logo-text {
        color: #fff;
        font-weight: 800;
        font-size: 1.1rem;
        letter-spacing: -0.02em;
    }

    .auth-panel-headline {
        position: relative;
        z-index: 1;
        margin-top: auto;
    }

    .auth-panel-headline h2 {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.25;
        margin-bottom: 14px;
    }

    .auth-panel-headline h2 span {
        background: linear-gradient(135deg, #818cf8, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .auth-panel-headline p {
        color: #6b7280;
        font-size: 0.875rem;
        line-height: 1.6;
        margin-bottom: 24px;
    }

    .auth-feature-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .auth-feature-list li {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #9ca3af;
        font-size: 0.82rem;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .auth-feature-list li i {
        width: 22px;
        height: 22px;
        background: rgba(88,101,242,0.15);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #818cf8;
        font-size: 0.7rem;
        flex-shrink: 0;
    }

    /* Dot grid decoration */
    .auth-dot-grid {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 200px;
        height: 200px;
        background-image: radial-gradient(circle, rgba(255,255,255,0.08) 1px, transparent 1px);
        background-size: 20px 20px;
        pointer-events: none;
        z-index: 0;
        opacity: 0.6;
    }

    /* ── Right panel (form) ── */
    .auth-form-side {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 24px;
    }

    .auth-form-box {
        width: 100%;
        max-width: 400px;
    }

    .auth-form-box .form-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: #0f172a;
        letter-spacing: -0.03em;
        margin-bottom: 4px;
    }

    .auth-form-box .form-subtitle {
        font-size: 0.85rem;
        color: #94a3b8;
        margin-bottom: 32px;
    }

    .auth-form-box .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

    .auth-input-group {
        position: relative;
        margin-bottom: 18px;
    }

    .auth-input-group .input-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 0.9rem;
        pointer-events: none;
        z-index: 2;
    }

    .auth-input-group .form-control {
        padding-left: 36px;
        height: 44px;
        font-size: 0.875rem;
        border-color: #e2e8f0;
        border-radius: 8px;
        transition: all 0.2s;
        background: #fff;
    }

    .auth-input-group .form-control:focus {
        border-color: #5865f2;
        box-shadow: 0 0 0 3px rgba(88,101,242,0.1);
    }

    .auth-input-group .password-toggle {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 0;
        font-size: 0.9rem;
        z-index: 2;
    }

    .auth-submit-btn {
        width: 100%;
        height: 44px;
        background: #5865f2;
        border: none;
        border-radius: 8px;
        color: #fff;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.01em;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .auth-submit-btn:hover {
        background: #4752c4;
        box-shadow: 0 4px 12px rgba(88,101,242,0.35);
        transform: translateY(-1px);
    }

    .auth-divider {
        text-align: center;
        position: relative;
        margin: 20px 0;
        color: #cbd5e1;
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.05em;
    }

    .auth-divider::before,
    .auth-divider::after {
        content: '';
        position: absolute;
        top: 50%;
        width: calc(50% - 30px);
        height: 1px;
        background: #e2e8f0;
    }

    .auth-divider::before { left: 0; }
    .auth-divider::after  { right: 0; }

    .auth-signup-btn {
        width: 100%;
        height: 44px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #374151;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .auth-signup-btn:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
        color: #0f172a;
    }

    .auth-legal {
        text-align: center;
        font-size: 0.72rem;
        color: #94a3b8;
        margin-top: 20px;
        line-height: 1.5;
    }

    .auth-legal a { color: #5865f2; font-weight: 600; }
    .auth-legal a:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .auth-panel { display: none; }
        .auth-form-side { background: #f0f4f9; }
    }
</style>
}

<div class="auth-wrapper">

    <!-- Left decorative panel -->
    <div class="auth-panel">
        <div class="auth-dot-grid"></div>

        <div class="auth-panel-logo">
            <div class="auth-panel-logo-icon">
                <i class="bi bi-envelope-fill"></i>
            </div>
            <span class="auth-panel-logo-text">MailTo</span>
        </div>

        <div class="auth-panel-headline">
            <h2>Email marketing that <span>actually works</span></h2>
            <p>Send smarter campaigns, grow your audience, and track every open and click — all in one place.</p>
            <ul class="auth-feature-list">
                <li><i class="bi bi-check-lg"></i> Import contacts from Excel in seconds</li>
                <li><i class="bi bi-check-lg"></i> Personalised campaigns at scale</li>
                <li><i class="bi bi-check-lg"></i> Real-time delivery &amp; open tracking</li>
                <li><i class="bi bi-check-lg"></i> Unlimited SMTP configuration</li>
            </ul>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-side">
        <div class="auth-form-box">

            <div class="form-title">Welcome back</div>
            <div class="form-subtitle">Sign in to your account to continue</div>

            <form id="account" method="post" novalidate>
                <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

                <!-- Email -->
                <div class="mb-1" style="font-size:0.8rem;font-weight:600;color:#374151;">Email address</div>
                <div class="auth-input-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" type="email" class="form-control" placeholder="you@company.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error"></span>

                <!-- Password -->
                <div class="d-flex align-items-center justify-content-between mb-1 mt-2">
                    <span style="font-size:0.8rem;font-weight:600;color:#374151;">Password</span>
                    <a asp-controller="Account" asp-action="ForgotPassword"
                       style="font-size:0.75rem;font-weight:600;color:#5865f2;">Forgot password?</a>
                </div>
                <div class="auth-input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" id="passwordInput" autocomplete="current-password" />
                    <button type="button" class="password-toggle" id="pwdToggle" tabindex="-1">
                        <i class="bi bi-eye" id="pwdToggleIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-validation-error"></span>

                <!-- Remember me -->
                <div class="d-flex align-items-center mb-4 mt-2">
                    <div class="form-check mb-0">
                        <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe"
                               style="border-color:#cbd5e1;border-radius:4px;cursor:pointer;" />
                        <label class="form-check-label" for="rememberMe"
                               style="font-size:0.82rem;color:#374151;font-weight:500;cursor:pointer;">
                            Keep me signed in
                        </label>
                    </div>
                </div>

                <button type="submit" class="auth-submit-btn">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>

            <div class="auth-divider">OR</div>

            <a asp-controller="Account" asp-action="Register" class="auth-signup-btn">
                <i class="bi bi-person-plus"></i> Create a free account
            </a>

            <div class="auth-legal">
                By signing in you agree to our
                <a asp-controller="Account" asp-action="TermsAndConditions">Terms &amp; Conditions</a>
                and <a asp-controller="Account" asp-action="TermsAndConditions">Privacy Policy</a>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Password visibility toggle
        var input = document.getElementById('passwordInput');
        var icon  = document.getElementById('pwdToggleIcon');
        document.getElementById('pwdToggle').addEventListener('click', function () {
            var isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.className = isPassword ? 'bi bi-eye-slash' : 'bi bi-eye';
        });
    </script>
}
