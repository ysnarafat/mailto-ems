@model ForgotPasswordModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_AccountLayout";
}

@section Styles {
<style>
    body { background: #f0f4f9; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .auth-card-wrap { width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 16px; }
    .auth-card {
        width: 100%; max-width: 440px;
        background: #fff; border: 1px solid #e2e8f0; border-radius: 14px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07); overflow: hidden;
    }
    .auth-card-header {
        background: #0d1117; padding: 32px 36px 28px; text-align: center;
        position: relative; overflow: hidden;
    }
    .auth-card-header::before {
        content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%);
        width: 300px; height: 200px;
        background: radial-gradient(ellipse, rgba(245,158,11,0.25) 0%, transparent 70%);
        pointer-events: none;
    }
    .auth-card-icon {
        width: 54px; height: 54px; border-radius: 14px;
        background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.3);
        display: flex; align-items: center; justify-content: center;
        color: #fbbf24; font-size: 1.4rem; margin: 0 auto 14px; position: relative;
    }
    .auth-card-title { color: #fff; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 4px; }
    .auth-card-sub { color: #6b7280; font-size: 0.82rem; margin: 0; }
    .auth-card-body { padding: 28px 36px 32px; }

    .auth-input-group { position: relative; }
    .auth-input-group .input-icon {
        position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
        color: #94a3b8; font-size: 0.9rem; pointer-events: none; z-index: 2;
    }
    .auth-input-group .form-control {
        padding-left: 36px; height: 44px; font-size: 0.875rem;
        border-color: #e2e8f0; border-radius: 8px; transition: all 0.2s;
    }
    .auth-input-group .form-control:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,0.1); }

    .auth-submit-btn {
        width: 100%; height: 44px; background: #f59e0b; border: none; border-radius: 8px;
        color: #fff; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s;
        display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 20px;
    }
    .auth-submit-btn:hover { background: #d97706; box-shadow: 0 4px 12px rgba(245,158,11,0.35); transform: translateY(-1px); }

    .auth-back-link {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 18px; font-size: 0.82rem; font-weight: 600; color: #64748b; text-decoration: none;
        transition: color 0.2s;
    }
    .auth-back-link:hover { color: #5865f2; }
</style>
}

<div class="auth-card-wrap">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-card-icon"><i class="bi bi-key-fill"></i></div>
            <div class="auth-card-title">Forgot your password?</div>
            <p class="auth-card-sub">Enter your email and we'll send reset instructions</p>
        </div>
        <div class="auth-card-body">
            <form method="post" novalidate>
                <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">Email Address</div>
                <div class="auth-input-group">
                    <i class="bi bi-envelope input-icon"></i>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter your account email" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="field-validation-error" style="font-size:0.78rem;margin-top:4px;display:block;"></span>

                <button type="submit" class="auth-submit-btn">
                    <i class="bi bi-send-fill"></i> Send Reset Link
                </button>
            </form>

            <a asp-controller="Account" asp-action="Login" class="auth-back-link">
                <i class="bi bi-arrow-left"></i> Back to Sign In
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
