@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Set New Password";
    Layout = "_AccountLayout";
}

@section Styles {
<style>
    body { background: #f0f4f9; min-height: 100vh; }
    .auth-card-wrap { width: 100%; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 16px; }
    .auth-card {
        width: 100%; max-width: 440px; background: #fff;
        border: 1px solid #e2e8f0; border-radius: 14px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07); overflow: hidden;
    }
    .auth-card-header {
        background: #0d1117; padding: 32px 36px 28px; text-align: center; position: relative; overflow: hidden;
    }
    .auth-card-header::before {
        content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%);
        width: 300px; height: 200px;
        background: radial-gradient(ellipse, rgba(88,101,242,0.25) 0%, transparent 70%);
        pointer-events: none;
    }
    .auth-card-icon {
        width: 54px; height: 54px; border-radius: 14px;
        background: rgba(88,101,242,0.15); border: 1px solid rgba(88,101,242,0.3);
        display: flex; align-items: center; justify-content: center;
        color: #818cf8; font-size: 1.4rem; margin: 0 auto 14px; position: relative;
    }
    .auth-card-title { color: #fff; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 4px; }
    .auth-card-sub { color: #6b7280; font-size: 0.82rem; margin: 0; }
    .auth-card-body { padding: 28px 36px 32px; }

    .auth-input-group { position: relative; margin-bottom: 14px; }
    .auth-input-group .input-icon {
        position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
        color: #94a3b8; font-size: 0.9rem; pointer-events: none; z-index: 2;
    }
    .auth-input-group .form-control {
        padding-left: 36px; height: 44px; font-size: 0.875rem;
        border-color: #e2e8f0; border-radius: 8px; transition: all 0.2s;
    }
    .auth-input-group .form-control:focus { border-color: #5865f2; box-shadow: 0 0 0 3px rgba(88,101,242,0.1); }
    .auth-input-group .password-toggle {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        background: none; border: none; color: #94a3b8; cursor: pointer; padding: 0; font-size: 0.9rem; z-index: 2;
    }

    .pwd-strength {
        margin-top: 6px; height: 4px; background: #f1f5f9; border-radius: 2px; overflow: hidden;
    }
    .pwd-strength-bar {
        height: 100%; border-radius: 2px; transition: width 0.3s, background 0.3s;
        width: 0; background: #ef4444;
    }

    .auth-submit-btn {
        width: 100%; height: 44px; background: #5865f2; border: none; border-radius: 8px;
        color: #fff; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.2s;
        display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 8px;
    }
    .auth-submit-btn:hover { background: #4752c4; box-shadow: 0 4px 12px rgba(88,101,242,0.35); transform: translateY(-1px); }

    .auth-back-link {
        display: flex; align-items: center; justify-content: center; gap: 6px;
        margin-top: 18px; font-size: 0.82rem; font-weight: 600; color: #64748b; text-decoration: none; transition: color 0.2s;
    }
    .auth-back-link:hover { color: #5865f2; }
</style>
}

<div class="auth-card-wrap">
    <div class="auth-card">
        <div class="auth-card-header">
            <div class="auth-card-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <div class="auth-card-title">Set a new password</div>
            <p class="auth-card-sub">Choose a strong password you haven't used before</p>
        </div>
        <div class="auth-card-body">
            <form asp-controller="Account" asp-action="ResetPassword" method="post" novalidate>
                <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

                <input asp-for="Email" type="hidden" />
                <input asp-for="Code" type="hidden" />

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">New Password</div>
                <div class="auth-input-group">
                    <i class="bi bi-lock input-icon"></i>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter new password"
                           id="newPwd" autocomplete="new-password" />
                    <button type="button" class="password-toggle" onclick="togglePwd('newPwd','icon1')" tabindex="-1">
                        <i class="bi bi-eye" id="icon1"></i>
                    </button>
                </div>
                <div class="pwd-strength mb-2"><div class="pwd-strength-bar" id="pwdBar"></div></div>
                <span asp-validation-for="Password" class="field-validation-error" style="font-size:0.78rem;display:block;margin-bottom:8px;"></span>

                <div style="font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:6px;">Confirm New Password</div>
                <div class="auth-input-group">
                    <i class="bi bi-lock-fill input-icon"></i>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repeat your password"
                           id="confPwd" autocomplete="new-password" />
                    <button type="button" class="password-toggle" onclick="togglePwd('confPwd','icon2')" tabindex="-1">
                        <i class="bi bi-eye" id="icon2"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="field-validation-error" style="font-size:0.78rem;display:block;margin-bottom:8px;"></span>

                <button type="submit" class="auth-submit-btn">
                    <i class="bi bi-check-circle-fill"></i> Update Password
                </button>
            </form>

            <a asp-controller="Account" asp-action="Login" class="auth-back-link">
                <i class="bi bi-arrow-left"></i> Back to Sign In
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePwd(inputId, iconId) {
            var el = document.getElementById(inputId), icon = document.getElementById(iconId);
            var show = el.type === 'password';
            el.type = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
        // Simple password strength indicator
        document.getElementById('newPwd').addEventListener('input', function () {
            var val = this.value, bar = document.getElementById('pwdBar');
            var score = 0;
            if (val.length >= 6) score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;
            var colors = ['#ef4444','#f59e0b','#f59e0b','#22c55e','#22c55e'];
            var widths = ['20%','40%','60%','80%','100%'];
            bar.style.width = val.length ? (widths[score - 1] || '20%') : '0';
            bar.style.background = val.length ? (colors[score - 1] || '#ef4444') : '#ef4444';
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}
