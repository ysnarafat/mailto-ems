@model ProfileInformationModel
@{
    ViewData["Title"] = "My Profile";
    var initial = string.IsNullOrEmpty(Model.FullName) ? "A" : Model.FullName.Substring(0, 1).ToUpper();
}

<div class="page-header">
    <h1 class="page-title">My Profile</h1>
    <a asp-area="Admin" asp-controller="Profile" asp-action="UpdateInformation" class="btn btn-primary">
        <i class="bi bi-pencil"></i> Edit Profile
    </a>
</div>

<div class="row g-3" style="max-width:760px;">
    <div class="col-12">
        <div class="card">
            <div class="card-body d-flex align-items-center gap-4 flex-wrap">
                <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#0d1117,#1e2035);display:flex;align-items:center;justify-content:center;font-size:1.8rem;font-weight:800;color:#818cf8;flex-shrink:0;border:3px solid rgba(88,101,242,0.3);">
                    @initial
                </div>
                <div>
                    <div style="font-size:1.2rem;font-weight:800;color:#0f172a;letter-spacing:-0.02em;">@(Model.FullName ?? "—")</div>
                    <div style="font-size:0.85rem;color:#94a3b8;margin-top:3px;">@(Model.Email ?? "—")</div>
                    <span class="badge badge-soft-primary mt-1">Administrator</span>
                </div>
                <div class="ms-auto">
                    <a asp-area="Admin" asp-controller="Profile" asp-action="ChangePassword" class="btn btn-light btn-sm">
                        <i class="bi bi-key"></i> Change Password
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h6 class="card-header-title"><i class="bi bi-person me-2 text-accent"></i>Personal Information</h6>
            </div>
            <div class="card-body">
                <div class="row g-0">
                    @{
                        void Row(string label, string icon, string val) {
                            <div class="col-12 d-flex align-items-start gap-3 py-3" style="border-bottom:1px solid #f1f5f9;">
                                <div style="width:32px;height:32px;border-radius:8px;background:rgba(88,101,242,0.08);display:flex;align-items:center;justify-content:center;color:#5865f2;flex-shrink:0;font-size:0.85rem;">
                                    <i class="bi @icon"></i>
                                </div>
                                <div>
                                    <div style="font-size:0.72rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:2px;">@label</div>
                                    <div style="font-size:0.875rem;font-weight:500;color:@(string.IsNullOrEmpty(val)?"#cbd5e1":"#0f172a");">
                                        @(string.IsNullOrEmpty(val) ? "Not set" : val)
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    @{ Row("Full Name",    "bi-person",           Model.FullName); }
                    @{ Row("Email",        "bi-envelope",         Model.Email); }
                    @{ Row("Phone",        "bi-telephone",        Model.PhoneNumber); }
                    @{ Row("Gender",       "bi-gender-ambiguous", Model.Gender); }
                    @{ Row("Date of Birth","bi-calendar2",        Model.DateOfBirth?.ToString("dd MMM yyyy")); }
                    <div class="col-12 d-flex align-items-start gap-3 py-3">
                        <div style="width:32px;height:32px;border-radius:8px;background:rgba(88,101,242,0.08);display:flex;align-items:center;justify-content:center;color:#5865f2;flex-shrink:0;font-size:0.85rem;"><i class="bi bi-geo-alt"></i></div>
                        <div>
                            <div style="font-size:0.72rem;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:2px;">Address</div>
                            <div style="font-size:0.875rem;font-weight:500;color:@(string.IsNullOrEmpty(Model.Address)?"#cbd5e1":"#0f172a");white-space:pre-line;">@(string.IsNullOrEmpty(Model.Address)?"Not set":Model.Address)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
