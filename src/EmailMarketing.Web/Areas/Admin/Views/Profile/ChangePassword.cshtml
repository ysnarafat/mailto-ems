@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <h1 class="page-title">Change Password</h1>
    <a asp-area="Admin" asp-controller="Profile" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Back to Profile
    </a>
</div>

<div class="card" style="max-width:480px;">
    <div class="card-header">
        <h6 class="card-header-title"><i class="bi bi-key-fill me-2 text-accent"></i>Update Password</h6>
    </div>
    <div class="card-body">
        <partial name="_ActionMessage" model="@Model.Response" />
        <form asp-action="ChangePassword" asp-controller="Profile" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

            <div class="mb-3">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Current Password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" />
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>
            <div class="mb-3">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">New Password</label>
                <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 6 characters" />
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>
            <div class="mb-4">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Repeat new password" />
                <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-check-circle"></i> Update Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
