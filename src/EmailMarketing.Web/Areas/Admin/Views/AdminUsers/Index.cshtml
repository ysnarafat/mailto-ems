@model AdminUsersModel
@{
    ViewData["Title"] = "Admin Users";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Admin Users</h1>
        <p class="page-subtitle">Manage platform administrators</p>
    </div>
    <a asp-controller="AdminUsers" asp-action="Add" asp-area="Admin" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Add Admin
    </a>
</div>

<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <div class="table-responsive">
        <table class="table table-hover" id="user-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Verified</th>
                    <th>Phone</th>
                    <th>Status</th>
                    <th class="text-center" style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Delete modal -->
<div id="modal-delete" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-trash3-fill text-danger me-2"></i>Delete Admin</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">Are you sure you want to delete this admin? This cannot be undone.</p>
                <form id="deleteForm" action="@Url.Action("Delete", "AdminUsers", new { Area = "Admin" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="id" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="deleteButton" class="btn btn-danger btn-sm"><i class="bi bi-trash3"></i> Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- Block/Unblock modal -->
<div id="modal-blockUser" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-shield-exclamation text-warning me-2"></i><span id="blockUserTitle">Block User</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">Are you sure you want to <strong><span id="blockUserSure">block</span></strong> this user?</p>
                <form id="blockUserdForm" action="@Url.Action("BlockUser", "AdminUsers", new { Area = "Admin" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="blockId" name="id" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="blockButton" class="btn btn-warning btn-sm text-white">
                    <span id="blockUserButton">Block</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Reset Password modal -->
<div id="modal-resetUserPassword" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-key-fill text-accent me-2"></i>Reset Password</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">This will reset the user's password to the system default. Continue?</p>
                <form id="resetUserdPasswordForm" action="@Url.Action("ResetPassword", "AdminUsers", new { Area = "Admin" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="resetId" name="id" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="resetButton" class="btn btn-primary btn-sm"><i class="bi bi-key"></i> Reset</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ajax-call.js"></script>
    <script src="~/js/project/adminusers.js"></script>
    <script>
        $(function () {
            var url                = '@Url.Action("GetUsers",         "AdminUsers", new { Area = "Admin" })';
            var editUrl            = '@Url.Action("Edit",             "AdminUsers", new { Area = "Admin" })';
            var userInformationUrl = '@Url.Action("UserInformation",  "AdminUsers", new { Area = "Admin" })';
            loadDatatable(url, editUrl, userInformationUrl);

            $('#modal-delete').on('show.bs.modal', function (e) {
                $("#deleteId").val($(e.relatedTarget).attr('data-id'));
            });
            $("#deleteButton").click(function () { $("#deleteForm").submit(); });

            $('#modal-blockUser').on('show.bs.modal', function (e) {
                var blocked = $(e.relatedTarget).attr('data-title') === 'Yes';
                $("#blockId").val($(e.relatedTarget).attr('data-id'));
                $("#blockUserTitle").text(blocked ? 'Unblock User' : 'Block User');
                $("#blockUserSure").text(blocked ? 'unblock' : 'block');
                $("#blockUserButton").text(blocked ? 'Unblock' : 'Block');
            });
            $("#blockButton").click(function () { $("#blockUserdForm").submit(); });

            $('#modal-resetUserPassword').on('show.bs.modal', function (e) {
                $("#resetId").val($(e.relatedTarget).attr('data-id'));
            });
            $("#resetButton").click(function () { $("#resetUserdPasswordForm").submit(); });
        });
    </script>
}
