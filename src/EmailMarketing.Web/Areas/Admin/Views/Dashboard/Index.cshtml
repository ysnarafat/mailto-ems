@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title">Admin Dashboard</h1>
        <p class="page-subtitle">Platform overview and user management.</p>
    </div>
    <a asp-area="Admin" asp-controller="MemberUsers" asp-action="Add" class="btn btn-primary">
        <i class="bi bi-person-plus-fill"></i> Add Member
    </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon indigo"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalUser</div>
                    <div class="stat-card-label">Total Users</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon green"><i class="bi bi-send-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalMailSent</div>
                    <div class="stat-card-label">Emails Sent</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon amber"><i class="bi bi-megaphone-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalCampaigns</div>
                    <div class="stat-card-label">Campaigns</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon violet"><i class="bi bi-collection-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalContacts</div>
                    <div class="stat-card-label">Contacts</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick links -->
<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h6 class="card-header-title"><i class="bi bi-grid me-2 text-accent"></i>Management</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-6">
                        <div class="card border action-card">
                            <div class="action-card-icon indigo" style="background:rgba(88,101,242,0.1);">
                                <i class="bi bi-shield-person" style="color:#5865f2;"></i>
                            </div>
                            <h6>Admin Users</h6>
                            <p>Manage platform administrators and their permissions.</p>
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Index" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> View Admins
                                </a>
                                <a asp-area="Admin" asp-controller="AdminUsers" asp-action="Add" class="btn btn-primary btn-sm">
                                    <i class="bi bi-plus-lg"></i> Add
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card border action-card">
                            <div class="action-card-icon green" style="background:rgba(34,197,94,0.1);">
                                <i class="bi bi-people-fill" style="color:#16a34a;"></i>
                            </div>
                            <h6>Member Users</h6>
                            <p>View and manage all registered member accounts.</p>
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-area="Admin" asp-controller="MemberUsers" asp-action="Index" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-eye"></i> View Members
                                </a>
                                <a asp-area="Admin" asp-controller="MemberUsers" asp-action="Add" class="btn btn-success btn-sm">
                                    <i class="bi bi-plus-lg"></i> Add
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100" style="border:none;background:linear-gradient(135deg,#0d1117 0%,#1e2035 100%);color:#fff;">
            <div class="card-body" style="padding:28px;">
                <div style="width:48px;height:48px;background:rgba(88,101,242,0.25);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:16px;color:#818cf8;">
                    <i class="bi bi-bar-chart-fill"></i>
                </div>
                <div style="font-size:1.5rem;font-weight:800;letter-spacing:-0.03em;margin-bottom:4px;">@Model.TotalUser</div>
                <div style="font-size:0.8rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.07em;font-weight:600;margin-bottom:20px;">Total Platform Users</div>
                <div style="height:1px;background:rgba(255,255,255,0.08);margin-bottom:20px;"></div>
                <div class="d-flex justify-content-between" style="font-size:0.82rem;">
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-weight:500;margin-bottom:4px;">Emails Sent</div>
                        <div style="font-weight:700;color:#fff;">@Model.TotalMailSent</div>
                    </div>
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-weight:500;margin-bottom:4px;">Campaigns</div>
                        <div style="font-weight:700;color:#fff;">@Model.TotalCampaigns</div>
                    </div>
                    <div>
                        <div style="color:rgba(255,255,255,0.4);font-weight:500;margin-bottom:4px;">Contacts</div>
                        <div style="font-weight:700;color:#fff;">@Model.TotalContacts</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
