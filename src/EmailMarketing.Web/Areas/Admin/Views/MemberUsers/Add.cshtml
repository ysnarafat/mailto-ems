@model CreateMemberUserModel
@{
    ViewData["Title"] = "Add Member";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add Member</h1>
        <p class="page-subtitle">Create a new member account</p>
    </div>
    <a asp-controller="MemberUsers" asp-action="Index" asp-area="Admin" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="card" style="max-width:680px;">
    <div class="card-header">
        <h6 class="card-header-title"><i class="bi bi-person-plus-fill me-2 text-accent"></i>Member Details</h6>
    </div>
    <div class="card-body">
        <partial name="_ActionMessage" model="@Model.Response" />
        <form asp-action="Add" asp-controller="MemberUsers" asp-area="Admin" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label required" asp-for="FullName"></label>
                    <input type="text" class="form-control" asp-for="FullName" placeholder="Full name" />
                    <span asp-validation-for="FullName" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="Email"></label>
                    <input type="email" class="form-control" asp-for="Email" placeholder="email@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" asp-for="PhoneNumber"></label>
                    <input type="text" class="form-control" asp-for="PhoneNumber" placeholder="+1 234 567 890" />
                    <span asp-validation-for="PhoneNumber" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" asp-for="Gender"></label>
                    <select asp-for="Gender" class="form-select">
                        <option value="">— Select gender —</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="Gender" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label" asp-for="Address"></label>
                    <textarea class="form-control" asp-for="Address" rows="2" placeholder="Street, city, country"></textarea>
                    <span asp-validation-for="Address" class="field-validation-error"></span>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mt-4 pt-2 border-top">
                <a asp-controller="MemberUsers" asp-action="Index" asp-area="Admin" class="btn btn-light">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Create Member
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
