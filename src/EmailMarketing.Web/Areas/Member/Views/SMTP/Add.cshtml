@model EmailMarketing.Web.Areas.Member.Models.Smtp.CreateSMTPModel
@{
    ViewData["Title"] = "Add SMTP";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Add SMTP Server</h1>
        <p class="page-subtitle">Connect an email server for sending campaigns</p>
    </div>
    <a asp-controller="SMTP" asp-action="Index" asp-area="Member" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>

<div class="card">
    <div class="card-header">
        <h6 class="card-header-title"><i class="bi bi-hdd-network-fill me-2 text-accent"></i>Server Details</h6>
    </div>
    <div class="card-body">
        <partial name="_ActionMessage" model="@Model.Response" />
        <form asp-action="Add" asp-controller="SMTP" asp-area="Member" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label required" asp-for="Server"></label>
                    <input type="text" id="server" class="form-control" asp-for="Server" placeholder="smtp.gmail.com" />
                    <span asp-validation-for="Server" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="Port"></label>
                    <input type="text" id="port" class="form-control" asp-for="Port" placeholder="465" />
                    <span asp-validation-for="Port" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="SenderName"></label>
                    <input type="text" id="sender_name" class="form-control" asp-for="SenderName" placeholder="My Company" />
                    <span asp-validation-for="SenderName" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="SenderEmail"></label>
                    <input type="text" id="sender_email" class="form-control" asp-for="SenderEmail" placeholder="noreply@company.com" />
                    <span asp-validation-for="SenderEmail" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="UserName"></label>
                    <input type="text" id="user_name" class="form-control" asp-for="UserName" />
                    <span asp-validation-for="UserName" class="field-validation-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label required" asp-for="Password"></label>
                    <div style="position:relative;">
                        <input type="password" id="password" class="form-control" asp-for="Password" style="padding-right:40px;" />
                        <button type="button" onclick="var el=document.getElementById('password');var i=document.getElementById('pwdIcon');el.type=el.type==='password'?'text':'password';i.className=el.type==='password'?'bi bi-eye':'bi bi-eye-slash';"
                                style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;" tabindex="-1">
                            <i class="bi bi-eye" id="pwdIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                </div>
                <div class="col-12">
                    <div class="d-flex align-items-center gap-2">
                        <input type="checkbox" id="enable_ssl" class="form-check-input" asp-for="EnableSSL"
                               style="border-color:#cbd5e1;border-radius:4px;cursor:pointer;" />
                        <label for="enable_ssl" class="form-label mb-0" style="cursor:pointer;">
                            Enable SSL / TLS encryption
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-between mt-4 pt-2 border-top">
                <a asp-controller="SMTP" asp-action="Index" asp-area="Member" class="btn btn-light">
                    <i class="bi bi-arrow-left"></i> Cancel
                </a>
                <div class="d-flex gap-2">
                    <button type="button" id="smtpTestBtn" class="btn btn-outline-primary">
                        <i class="bi bi-shield-check"></i> Test Connection
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i> Save
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/ajax-call.js"></script>
    <script>
        $('#smtpTestBtn').click(function (e) {
            e.preventDefault();
            var btn = $(this);
            btn.html('<span class="spinner-border spinner-border-sm me-1"></span> Testing...').prop('disabled', true);
            var data = {
                Server: $('#server').val(), Port: parseInt($('#port').val()),
                SenderName: $('#sender_name').val(), SenderEmail: $('#sender_email').val(),
                UserName: $('#user_name').val(), Password: $('#password').val(),
                EnableSSL: $('#enable_ssl').is(':checked')
            };
            $.ajax({
                url: '@Url.Action("TestSmtp", "SMTP", new { Area = "Member" })',
                type: 'POST', contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (r) {
                    if (r === true) showToast('SMTP connection successful!', 'success');
                    else if (r === 'failed') showToast('Please fill in all fields.', 'error');
                    else showToast('Invalid SMTP settings — connection failed.', 'error');
                },
                error: function () { showToast('Connection test failed.', 'error'); },
                complete: function () { btn.html('<i class="bi bi-shield-check"></i> Test Connection').prop('disabled', false); }
            });
        });
    </script>
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
