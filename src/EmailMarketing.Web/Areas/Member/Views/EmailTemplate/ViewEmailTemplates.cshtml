@model EmailTemplateModel
@{
    ViewData["Title"] = "Email Templates";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Email Templates</h1>
        <p class="page-subtitle">Reusable designs for your campaigns</p>
    </div>
    <a asp-controller="EmailTemplate" asp-action="AddEmailTemplate" asp-area="Member" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create Template
    </a>
</div>

@if (!Model.EmailTemplateList.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-state-icon" style="background:rgba(245,158,11,0.1);color:#d97706;">
                <i class="bi bi-file-earmark-richtext"></i>
            </div>
            <h6>No templates yet</h6>
            <p>Create your first email template to use in campaigns. You can personalise it with contact field tags.</p>
            <a asp-controller="EmailTemplate" asp-action="AddEmailTemplate" asp-area="Member" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg"></i> Create your first template
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @{
            var count = Model.EmailTemplateList.Count();
        }
        @for (int j = 0; j < count; j++)
        {
            <div class="col-sm-6 col-lg-4">
                <div class="card h-100" style="overflow:hidden;">
                    <!-- Template preview -->
                    <div class="position-relative" style="height:160px;overflow:hidden;background:#f8fafc;border-bottom:1px solid var(--border-color);">
                        <div style="transform:scale(0.55);transform-origin:top left;width:182%;pointer-events:none;padding:8px;">
                            @Html.Raw(Model.EmailTemplateList[j].EmailTemplateBody)
                        </div>
                        <!-- Hover overlay -->
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center gap-2"
                             style="background:rgba(13,17,23,0.6);opacity:0;transition:opacity 0.2s;"
                             onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0'">
                            <a class="btn btn-sm btn-light selected_template_preview"
                               data-bs-toggle="modal" data-bs-target="#templatebody"
                               data-template-body="@System.Web.HttpUtility.HtmlAttributeEncode(Model.EmailTemplateList[j].EmailTemplateBody)"
                               data-template-name="@Model.EmailTemplateList[j].EmailTemplateName">
                                <i class="bi bi-eye"></i> Preview
                            </a>
                        </div>
                    </div>
                    <!-- Footer -->
                    <div class="card-body py-3 px-3 d-flex align-items-center justify-content-between">
                        <div>
                            <div style="font-size:0.85rem;font-weight:700;color:#0f172a;">
                                @Model.EmailTemplateList[j].EmailTemplateName
                            </div>
                            @if (Model.EmailTemplateList[j].IsPersonalized)
                            {
                                <span class="badge badge-soft-primary" style="font-size:0.65rem;">Personalised</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Preview modal -->
<div class="modal fade" id="templatebody" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-eye me-2 text-accent"></i><span id="templateModalTitle">Template Preview</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="templateModalBody" style="min-height:300px;"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.selected_template_preview').forEach(function (el) {
            el.addEventListener('click', function () {
                document.getElementById('templateModalTitle').textContent = this.getAttribute('data-template-name') || 'Template Preview';
                document.getElementById('templateModalBody').innerHTML = this.getAttribute('data-template-body') || '';
            });
        });
    </script>
}
