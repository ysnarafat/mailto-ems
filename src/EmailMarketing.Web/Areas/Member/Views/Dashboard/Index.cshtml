@model DashboardModel
@using EmailMarketing.Membership.Extensions
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Dashboard";
    var fullName    = User.Identity.FullName();
    var initial     = string.IsNullOrEmpty(fullName) ? "U" : fullName.Substring(0, 1).ToUpper();
    var companyName = Configuration.GetSection("AppSettings")["CompanyFullName"];
    var companyPhone = Configuration.GetSection("AppSettings")["CompanyPhoneNo"];
    var companyEmail = Configuration.GetSection("AppSettings")["CompanyEmail"];
}

<!-- Welcome -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title">Welcome back, @fullName 👋</h1>
        <p class="page-subtitle">Here's your overview for today.</p>
    </div>
    <a asp-area="Member" asp-controller="Campaigns" asp-action="AddCampaign" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Campaign
    </a>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-4">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon indigo"><i class="bi bi-send-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalCampaigns</div>
                    <div class="stat-card-label">Campaigns</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon green"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalContacts</div>
                    <div class="stat-card-label">Contacts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-4">
        <div class="card">
            <div class="stat-card-row">
                <div class="stat-card-icon violet"><i class="bi bi-collection-fill"></i></div>
                <div>
                    <div class="stat-card-value">@Model.TotalGroups</div>
                    <div class="stat-card-label">Groups</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">

    <!-- Left: Quick actions + chart -->
    <div class="col-lg-8">

        <!-- Quick actions -->
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="card-header-title"><i class="bi bi-grid me-2 text-accent"></i>Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6 col-md-3">
                        <a asp-area="Member" asp-controller="Campaigns" asp-action="Index"
                           class="d-block text-center p-3 rounded-3 text-decoration-none" style="background:#f8f9ff;border:1px solid rgba(88,101,242,0.12);transition:all 0.2s;" onmouseover="this.style.background='rgba(88,101,242,0.08)'" onmouseout="this.style.background='#f8f9ff'">
                            <i class="bi bi-send-fill d-block mb-2" style="font-size:1.4rem;color:#5865f2;"></i>
                            <span style="font-size:0.78rem;font-weight:600;color:#374151;">Campaigns</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="Member" asp-controller="Contacts" asp-action="Index"
                           class="d-block text-center p-3 rounded-3 text-decoration-none" style="background:#f0fdf4;border:1px solid rgba(34,197,94,0.12);transition:all 0.2s;" onmouseover="this.style.background='rgba(34,197,94,0.08)'" onmouseout="this.style.background='#f0fdf4'">
                            <i class="bi bi-people-fill d-block mb-2" style="font-size:1.4rem;color:#16a34a;"></i>
                            <span style="font-size:0.78rem;font-weight:600;color:#374151;">Contacts</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="Member" asp-controller="EmailTemplate" asp-action="ViewEmailTemplates"
                           class="d-block text-center p-3 rounded-3 text-decoration-none" style="background:#fffbeb;border:1px solid rgba(245,158,11,0.12);transition:all 0.2s;" onmouseover="this.style.background='rgba(245,158,11,0.08)'" onmouseout="this.style.background='#fffbeb'">
                            <i class="bi bi-file-earmark-richtext-fill d-block mb-2" style="font-size:1.4rem;color:#d97706;"></i>
                            <span style="font-size:0.78rem;font-weight:600;color:#374151;">Templates</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-area="Member" asp-controller="SMTP" asp-action="Index"
                           class="d-block text-center p-3 rounded-3 text-decoration-none" style="background:#f0f9ff;border:1px solid rgba(14,165,233,0.12);transition:all 0.2s;" onmouseover="this.style.background='rgba(14,165,233,0.08)'" onmouseout="this.style.background='#f0f9ff'">
                            <i class="bi bi-hdd-network-fill d-block mb-2" style="font-size:1.4rem;color:#0284c7;"></i>
                            <span style="font-size:0.78rem;font-weight:600;color:#374151;">SMTP</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Overview chart -->
        <div class="card">
            <div class="card-header">
                <h6 class="card-header-title"><i class="bi bi-bar-chart-fill me-2 text-accent"></i>Platform Overview</h6>
                <span style="font-size:0.72rem;color:#94a3b8;">All-time totals</span>
            </div>
            <div class="card-body">
                <div class="row align-items-center g-3">
                    <div class="col-md-5 d-flex justify-content-center">
                        <div style="position:relative;width:180px;height:180px;">
                            <canvas id="overviewChart" width="180" height="180"></canvas>
                            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
                                <div style="font-size:1.5rem;font-weight:800;color:#0f172a;letter-spacing:-0.03em;line-height:1;">
                                    @(Model.TotalCampaigns + Model.TotalContacts + Model.TotalGroups)
                                </div>
                                <div style="font-size:0.68rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Total</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="d-flex flex-column gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:10px;height:10px;border-radius:3px;background:#5865f2;flex-shrink:0;"></div>
                                <div style="flex:1;">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span style="font-size:0.8rem;font-weight:500;color:#374151;">Campaigns</span>
                                        <span style="font-size:0.8rem;font-weight:700;color:#0f172a;">@Model.TotalCampaigns</span>
                                    </div>
                                    <div style="height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden;">
                                        <div style="height:100%;background:#5865f2;border-radius:3px;width:@(Model.TotalCampaigns > 0 ? Math.Min(100, Model.TotalCampaigns * 10) : 5)%;"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:10px;height:10px;border-radius:3px;background:#22c55e;flex-shrink:0;"></div>
                                <div style="flex:1;">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span style="font-size:0.8rem;font-weight:500;color:#374151;">Contacts</span>
                                        <span style="font-size:0.8rem;font-weight:700;color:#0f172a;">@Model.TotalContacts</span>
                                    </div>
                                    <div style="height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden;">
                                        <div style="height:100%;background:#22c55e;border-radius:3px;width:@(Model.TotalContacts > 0 ? Math.Min(100, Model.TotalContacts / 10) : 5)%;"></div>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <div style="width:10px;height:10px;border-radius:3px;background:#8b5cf6;flex-shrink:0;"></div>
                                <div style="flex:1;">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span style="font-size:0.8rem;font-weight:500;color:#374151;">Groups</span>
                                        <span style="font-size:0.8rem;font-weight:700;color:#0f172a;">@Model.TotalGroups</span>
                                    </div>
                                    <div style="height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden;">
                                        <div style="height:100%;background:#8b5cf6;border-radius:3px;width:@(Model.TotalGroups > 0 ? Math.Min(100, Model.TotalGroups * 15) : 5)%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Profile + exports + support -->
    <div class="col-lg-4">
        <!-- Profile card -->
        <div class="card mb-3" style="overflow:hidden;">
            <div style="background:linear-gradient(135deg,#5865f2 0%,#7c3aed 100%);padding:26px 20px 42px;text-align:center;position:relative;">
                <div style="position:absolute;top:-20px;right:-20px;width:90px;height:90px;background:rgba(255,255,255,0.06);border-radius:50%;"></div>
                <div style="width:60px;height:60px;background:rgba(255,255,255,0.2);border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:1.4rem;font-weight:800;color:#fff;border:3px solid rgba(255,255,255,0.3);margin-bottom:10px;">
                    @initial
                </div>
                <div style="color:#fff;font-weight:700;font-size:0.95rem;margin-bottom:2px;">@fullName</div>
                <div style="color:rgba(255,255,255,0.6);font-size:0.72rem;">Member Account</div>
            </div>
            <div style="margin-top:-14px;background:#fff;border-radius:12px 12px 0 0;padding:16px 20px;">
                <div style="background:linear-gradient(135deg,rgba(88,101,242,0.06),rgba(124,58,237,0.06));border-radius:8px;padding:12px;border:1px solid rgba(88,101,242,0.12);text-align:center;margin-bottom:12px;">
                    <div style="font-size:0.75rem;color:#5865f2;font-weight:600;margin-bottom:6px;">🎯 29 days left in your trial</div>
                    <a asp-area="Member" asp-controller="UpgrateMembership" asp-action="Index" class="btn btn-primary btn-sm w-100">Upgrade Plan</a>
                </div>
                <!-- Export shortcuts -->
                <div class="d-flex gap-2">
                    <a asp-area="Member" asp-controller="Campaigns" asp-action="ViewReport"
                       class="d-flex align-items-center gap-2 flex-1 text-decoration-none p-2 rounded-3"
                       style="background:#f8fafc;border:1px solid var(--border-color);transition:all 0.2s;font-size:0.75rem;font-weight:600;color:#374151;"
                       onmouseover="this.style.borderColor='#5865f2'" onmouseout="this.style.borderColor='var(--border-color)'">
                        <i class="bi bi-file-earmark-bar-graph" style="color:#5865f2;"></i> Campaign Report
                    </a>
                    <a asp-area="Member" asp-controller="Contacts" asp-action="Export"
                       class="d-flex align-items-center gap-2 flex-1 text-decoration-none p-2 rounded-3"
                       style="background:#f8fafc;border:1px solid var(--border-color);transition:all 0.2s;font-size:0.75rem;font-weight:600;color:#374151;"
                       onmouseover="this.style.borderColor='#22c55e'" onmouseout="this.style.borderColor='var(--border-color)'">
                        <i class="bi bi-person-check" style="color:#16a34a;"></i> Contacts
                    </a>
                </div>
            </div>
        </div>

        <!-- Support card -->
        @if (!string.IsNullOrEmpty(companyPhone) || !string.IsNullOrEmpty(companyEmail))
        {
            <div class="card">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div style="width:32px;height:32px;background:rgba(34,197,94,0.1);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#16a34a;flex-shrink:0;">
                            <i class="bi bi-headset"></i>
                        </div>
                        <div>
                            <div style="font-size:0.82rem;font-weight:700;color:#0f172a;">@companyName Support</div>
                            <div style="font-size:0.72rem;color:#94a3b8;">We're here to help</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(companyPhone))
                    {
                        <div class="d-flex align-items-center gap-2 mb-2" style="font-size:0.8rem;color:#374151;">
                            <i class="bi bi-telephone text-accent"></i><span>@companyPhone</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(companyEmail))
                    {
                        <div class="d-flex align-items-center gap-2" style="font-size:0.8rem;color:#374151;">
                            <i class="bi bi-envelope text-accent"></i><span>@companyEmail</span>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            var ctx = document.getElementById('overviewChart').getContext('2d');
            var campaigns = @Model.TotalCampaigns;
            var contacts  = @Model.TotalContacts;
            var groups    = @Model.TotalGroups;
            var total     = campaigns + contacts + groups;

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Campaigns', 'Contacts', 'Groups'],
                    datasets: [{
                        data: total > 0 ? [campaigns, contacts, groups] : [1, 1, 1],
                        backgroundColor: ['#5865f2', '#22c55e', '#8b5cf6'],
                        borderColor: '#ffffff',
                        borderWidth: 3,
                        hoverOffset: 4
                    }]
                },
                options: {
                    cutout: '72%',
                    plugins: { legend: { display: false }, tooltip: { enabled: total > 0 } },
                    animation: { animateScale: true, duration: 600 }
                }
            });
        })();
    </script>
}
