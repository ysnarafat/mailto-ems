@using EmailMarketing.Membership.Extensions
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    var userEmail    = User.Identity.Email();
    var userFullName = User.Identity.FullName();
    var initial      = string.IsNullOrEmpty(userFullName) ? "U" : userFullName.Substring(0, 1).ToUpper();
    var pageTitle    = ViewData["Title"]?.ToString() ?? "Dashboard";
}

<nav class="topbar">
    <!-- Mobile sidebar toggle -->
    <button class="topbar-toggle d-lg-none" id="sidebarToggle" type="button" aria-label="Toggle sidebar">
        <i class="bi bi-list"></i>
    </button>

    <!-- Page title -->
    <span class="topbar-title d-none d-md-block">@pageTitle</span>

    <!-- Actions -->
    <div class="topbar-actions">

        <!-- Notifications (placeholder) -->
        <div class="dropdown">
            <button class="topbar-icon-btn" data-bs-toggle="dropdown" aria-expanded="false" type="button">
                <i class="bi bi-bell"></i>
                <span class="topbar-badge"></span>
            </button>
            <div class="dropdown-menu dropdown-menu-end" style="width:300px;padding:0;overflow:hidden;">
                <div class="px-3 py-2 border-bottom d-flex align-items-center justify-content-between">
                    <span style="font-size:0.82rem;font-weight:700;color:#0f172a;">Notifications</span>
                    <span class="badge badge-soft-primary">New</span>
                </div>
                <div class="px-3 py-4 text-center" style="color:#94a3b8;font-size:0.82rem;">
                    <i class="bi bi-bell-slash d-block mb-2" style="font-size:1.5rem;"></i>
                    No new notifications
                </div>
            </div>
        </div>

        <!-- User dropdown -->
        <div class="dropdown">
            <button class="topbar-user-btn" data-bs-toggle="dropdown" aria-expanded="false" type="button">
                <div class="topbar-user-avatar-placeholder">@initial</div>
                <span class="topbar-user-name d-none d-md-block">@userEmail</span>
                <i class="bi bi-chevron-down d-none d-md-block" style="font-size:0.65rem;color:#94a3b8;"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li class="px-3 py-2 border-bottom" style="min-width:200px;">
                    <div style="font-size:0.82rem;font-weight:700;color:#0f172a;">@userFullName</div>
                    <div style="font-size:0.75rem;color:#94a3b8;">@userEmail</div>
                </li>
                <li>
                    <a asp-area="Member" asp-controller="Profile" asp-action="Index" class="dropdown-item mt-1">
                        <i class="bi bi-person"></i> My Profile
                    </a>
                </li>
                <li>
                    <a asp-area="Member" asp-controller="Profile" asp-action="ChangePassword" class="dropdown-item">
                        <i class="bi bi-key"></i> Change Password
                    </a>
                </li>
                <li>
                    <a asp-area="Member" asp-controller="UpgrateMembership" asp-action="Index" class="dropdown-item">
                        <i class="bi bi-lightning-charge"></i> Upgrade Plan
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-area="" asp-controller="Account" asp-action="Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right"></i> Sign Out
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>
</nav>
