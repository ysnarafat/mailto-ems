@model MenuModel
@using EmailMarketing.Membership.Extensions

@{
    var areaName       = this.ViewContext.RouteData.Values["area"]?.ToString();
    var controllerName = this.ViewContext.RouteData.Values["controller"]?.ToString();
    var actionName     = this.ViewContext.RouteData.Values["action"]?.ToString();
    var userFullName   = User.Identity.FullName();
    var userInitial    = string.IsNullOrEmpty(userFullName) ? "U" : userFullName.Substring(0, 1).ToUpper();
}

<aside class="sidebar" id="appSidebar">

    <!-- Brand -->
    <div class="sidebar-brand">
        <i class="bi bi-envelope-fill" style="color:#5865f2;font-size:1.3rem;"></i>
        <span class="sidebar-brand-text ms-2">MailTo</span>
    </div>

    <!-- Nav -->
    <div class="sidebar-body">

        <p class="sidebar-section-label">Main</p>
        <ul class="sidebar-nav">
            @{
                var isDashActive = controllerName == "Dashboard" && areaName == "Member";
            }
            <li class="nav-item">
                <a asp-area="Member" asp-controller="Dashboard" asp-action="Index"
                   class="nav-link @(isDashActive ? "active" : "")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Dashboard</span>
                </a>
            </li>

            @foreach (var menu in Model.MenuItems)
            {
                var isActive = menu.Children.Any(sm =>
                    controllerName == sm.Controller && actionName == sm.Action && areaName == sm.Area);
                var collapseId = "menu-" + menu.Title.Replace(" ", "-").ToLower();

                <li class="nav-item">
                    <a href="#@collapseId"
                       class="nav-link nav-submenu-toggle"
                       data-bs-toggle="collapse"
                       aria-expanded="@(isActive ? "true" : "false")"
                       aria-controls="@collapseId">
                        <i class="@menu.Icon"></i>
                        <span>@menu.Title</span>
                        <i class="bi bi-chevron-right nav-arrow"></i>
                    </a>
                    <div id="@collapseId" class="collapse @(isActive ? "show" : "")">
                        <ul class="sidebar-sub-nav">
                            @foreach (var sm in menu.Children)
                            {
                                var isSubActive = controllerName == sm.Controller && actionName == sm.Action && areaName == sm.Area;
                                <li class="nav-item">
                                    <a asp-area="@sm.Area" asp-controller="@sm.Controller" asp-action="@sm.Action"
                                       class="nav-link @(isSubActive ? "active" : "")">
                                        <i class="@sm.Icon"></i>
                                        <span>@sm.Title</span>
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                </li>
            }
        </ul>

        <p class="sidebar-section-label mt-2">Resources</p>
        <ul class="sidebar-nav">
            <li class="nav-item">
                <a asp-area="Member" asp-controller="Resources" asp-action="Index"
                   class="nav-link @(controllerName=="Resources" && actionName=="Index" ? "active":"")">
                    <i class="bi bi-lightning-charge-fill"></i>
                    <span>Get Started</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-area="Member" asp-controller="Resources" asp-action="SendMail"
                   class="nav-link @(controllerName=="Resources" && actionName=="SendMail" ? "active":"")">
                    <i class="bi bi-send"></i>
                    <span>How to Send Mail</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-area="Member" asp-controller="Resources" asp-action="ImportContact"
                   class="nav-link @(controllerName=="Resources" && actionName=="ImportContact" ? "active":"")">
                    <i class="bi bi-upload"></i>
                    <span>Import Contacts</span>
                </a>
            </li>
            <li class="nav-item">
                <a asp-area="Member" asp-controller="Resources" asp-action="ChoseEmailTemplate"
                   class="nav-link @(controllerName=="Resources" && actionName=="ChoseEmailTemplate" ? "active":"")">
                    <i class="bi bi-file-earmark-richtext"></i>
                    <span>Email Templates</span>
                </a>
            </li>
        </ul>

    </div>

    <!-- User -->
    <div class="sidebar-footer">
        <div class="dropdown">
            <div class="sidebar-user-info dropdown-toggle" data-bs-toggle="dropdown" style="cursor:pointer;">
                <div class="sidebar-user-avatar-placeholder">@userInitial</div>
                <div class="flex-1" style="overflow:hidden;">
                    <div class="sidebar-user-name">@userFullName</div>
                    <div class="sidebar-user-role">Member</div>
                </div>
                <i class="bi bi-three-dots-vertical" style="color:#6b7280;font-size:0.8rem;flex-shrink:0;"></i>
            </div>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <a asp-area="Member" asp-controller="Profile" asp-action="Index" class="dropdown-item">
                        <i class="bi bi-person"></i> My Profile
                    </a>
                </li>
                <li>
                    <a asp-area="Member" asp-controller="Profile" asp-action="ChangePassword" class="dropdown-item">
                        <i class="bi bi-key"></i> Change Password
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form asp-area="" asp-controller="Account" asp-action="Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item text-danger">
                            <i class="bi bi-box-arrow-right"></i> Sign Out
                        </button>
                    </form>
                </li>
            </ul>
        </div>
    </div>

</aside>
