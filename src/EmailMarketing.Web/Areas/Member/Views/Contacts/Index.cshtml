@model EmailMarketing.Web.Areas.Member.Models.Contacts.ContactsModel

@{
    ViewData["Title"] = "Contacts";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Contacts</h1>
        <p class="page-subtitle">Manage your contact list</p>
    </div>
    <div class="dropdown">
        <button class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown" type="button">
            <i class="bi bi-plus-lg"></i> Add Contact
        </button>
        <ul class="dropdown-menu dropdown-menu-end">
            <li>
                <a asp-area="Member" asp-controller="ContactUpload" asp-action="UploadContact" class="dropdown-item">
                    <i class="bi bi-upload"></i> Import from Excel
                </a>
            </li>
            <li>
                <a asp-area="Member" asp-controller="Contacts" asp-action="AddSingleContact" class="dropdown-item">
                    <i class="bi bi-person-plus"></i> Add Single Contact
                </a>
            </li>
        </ul>
    </div>
</div>

<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <div class="table-responsive">
        <table class="table table-hover datatable-basic" id="contact-table">
            <thead>
                <tr>
                    <th>Group</th>
                    <th>Email</th>
                    <th class="text-center" style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Delete Modal -->
<div id="modal-delete" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-exclamation-triangle-fill text-danger me-2"></i>Confirm Delete</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">Are you sure you want to delete this contact? This action cannot be undone.</p>
                <form id="deleteForm" action="@Url.Action("Delete", "Contacts", new { Area = "Member" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="deleteId" name="id" value="" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="deleteButton" class="btn btn-danger btn-sm">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/js/ajax-call.js"></script>
    <script src="~/js/project/contact.js"></script>
    <script>
        $(function () {
            var url              = '@Url.Action("GetContacts", "Contacts", new { Area = "Member" })';
            var editUrl          = '@Url.Action("EditContact", "Contacts", new { Area = "Member" })';
            var contactDetailsUrl = '@Url.Action("ContactDetails", "Contacts", new { Area = "Member" })';
            loadDatatable(url, editUrl, contactDetailsUrl);

            $('#modal-delete').on('show.bs.modal', function (e) {
                var id = $(e.relatedTarget).attr('data-id');
                $('#deleteId').val(id);
            });

            $('#deleteButton').click(function () {
                $('#deleteForm').submit();
            });
        });
    </script>
}
