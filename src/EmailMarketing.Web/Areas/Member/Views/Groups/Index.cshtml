@{
    ViewData["Title"] = "Groups";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Groups</h1>
        <p class="page-subtitle">Segment your contacts into targeted groups</p>
    </div>
    <button class="btn btn-primary" onclick="add_edit_Data('')">
        <i class="bi bi-plus-lg"></i> Create Group
    </button>
</div>

<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <div class="table-responsive">
        <table class="table table-hover" id="group-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Contacts</th>
                    <th>Status</th>
                    <th class="text-center" style="width:120px;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Add / Edit modal -->
<div id="addOrEditModal" class="modal fade" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="addOrEditModalTitle">
                    <i class="bi bi-collection-fill me-2 text-accent"></i>Add Group
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="addOrEditModalContent"></div>
        </div>
    </div>
</div>

<!-- Activate / Deactivate modal -->
<div id="modal-activeField" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title">
                    <i class="bi bi-toggle-on me-2 text-warning"></i>
                    <span id="activeFieldTitle">Activate Group</span>
                </h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">Are you sure you want to <strong><span id="activeFieldSure">activate</span></strong> this group?</p>
                <form id="activeFieldForm" action="@Url.Action("ActivateGroup", "Groups", new { Area = "Member" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="activeFieldId" name="id" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="activeButton" class="btn btn-primary btn-sm">
                    <span id="activeFieldButton">Activate</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/project/group.js"></script>
    <script src="~/js/ajax-call.js"></script>
    <script>
        $(function () {
            var url = '@Url.Action("GetGroups", "Groups", new { Area = "Member" })';
            loadDatatable(url);
        });

        function delete_Data(id) {
            var url = '@Url.Action("Delete", "Groups", new { Area = "Member" })';
            if (confirm('Are you sure you want to delete this group?')) {
                $.post(url, { id: id, __RequestVerificationToken: $('[name=__RequestVerificationToken]').val() }, function () { location.reload(); });
            }
        }

        function add_edit_Data(id) {
            $('#addOrEditModalTitle').html('<i class="bi bi-collection-fill me-2 text-accent"></i>' + (id ? 'Edit Group' : 'Add Group'));
            var url  = '@Url.Action("AddOrEdit", "Groups", new { Area = "Member" })';
            ajaxCallModal(url, { id: id }, 'renderStudentAddOrEditLoad', 'GET');
        }

        function renderStudentAddOrEditLoad(data) {
            $('#addOrEditModalContent').html(data);
            var modal = new bootstrap.Modal(document.getElementById('addOrEditModal'));
            modal.show();
        }

        $('#modal-activeField').on('show.bs.modal', function (e) {
            var id    = $(e.relatedTarget).attr('data-id');
            var title = $(e.relatedTarget).attr('data-title');
            var deact = title === 'Yes';
            $('#activeFieldId').val(id);
            $('#activeFieldTitle').text(deact ? 'Deactivate Group' : 'Activate Group');
            $('#activeFieldSure').text(deact ? 'deactivate' : 'activate');
            $('#activeFieldButton').text(deact ? 'Deactivate' : 'Activate');
        });

        $('#activeButton').click(function () { $('#activeFieldForm').submit(); });
    </script>
}
