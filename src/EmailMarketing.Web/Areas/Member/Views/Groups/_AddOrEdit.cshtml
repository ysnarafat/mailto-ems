@model GroupModel

<form asp-action="AddOrEdit" id="fieldmap-form">
    <div class="modal-body">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="font-size:0.82rem;padding:10px 14px;"></div>

        <label class="form-label required" asp-for="Name"></label>
        <input type="text" class="form-control" asp-for="Name" placeholder="e.g. Newsletter Subscribers" />
        <span asp-validation-for="Name" class="field-validation-error"></span>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">
            <i class="bi bi-x-lg"></i> Cancel
        </button>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-check-lg"></i> Save Group
        </button>
    </div>
</form>

<script>
    $.validator.unobtrusive.parse('#fieldmap-form');
</script>
