@model CampaignsModel
@{
    ViewData["Title"] = "Campaign Reports";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Campaign Reports</h1>
        <p class="page-subtitle">Download and track exported campaign reports</p>
    </div>
    <a asp-area="Member" asp-controller="Campaigns" asp-action="ViewReport" class="btn btn-primary">
        <i class="bi bi-file-earmark-arrow-down"></i> Export New Report
    </a>
</div>

<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <div class="table-responsive">
        <table class="table table-hover" id="downloadqueue-table">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Created</th>
                    <th>Status</th>
                    <th>Notify</th>
                    <th class="text-center" style="width:100px;">Download</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/js/project/downloadqueue.js"></script>
    <script>
        $(function () {
            var url         = '@Url.Action("GetCampaignReports", "Campaigns", new { Area = "Member" })';
            var downloadUrl = '@Url.Action("GetDownloadFile",    "Campaigns", new { Area = "Member" })';
            loadDatatable(url, downloadUrl, true);
        });
    </script>
}
