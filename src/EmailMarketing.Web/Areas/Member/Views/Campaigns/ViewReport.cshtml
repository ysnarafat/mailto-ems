@model CampaignsModel
@using EmailMarketing.Membership.Extensions
@{
    ViewData["Title"] = "Export Campaign Report";
    var loggedInUserEmail = User.Identity.Email();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Export Campaign Report</h1>
        <p class="page-subtitle">Download delivery data as an Excel file</p>
    </div>
    <a asp-controller="Campaigns" asp-action="Index" asp-area="Member" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Campaign List
    </a>
</div>

<partial name="_ActionMessage" model="@Model.Response" />

<div class="row g-3" style="max-width:820px;">

    <!-- Export all -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="card-header-title">
                    <i class="bi bi-file-earmark-bar-graph-fill me-2" style="color:#5865f2;"></i>All Campaigns
                </h6>
            </div>
            <div class="card-body">
                <p style="font-size:0.82rem;color:#64748b;margin-bottom:16px;line-height:1.6;">
                    Export the delivery report for every campaign in one Excel file.
                </p>
                <form asp-action="Export" asp-controller="Campaigns" asp-area="Member" method="post">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <input type="checkbox" id="notifyAll" class="form-check-input" asp-for="IsSendEmailNotifyForAll"
                               style="border-color:#cbd5e1;border-radius:4px;cursor:pointer;" />
                        <label for="notifyAll" style="font-size:0.82rem;font-weight:500;color:#374151;cursor:pointer;">
                            Email me when the export is ready
                        </label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Notify email(s)</label>
                        <input type="text" class="form-control" asp-for="SendEmailAddress" value="@loggedInUserEmail"
                               placeholder="email@example.com" />
                        <div style="font-size:0.72rem;color:#94a3b8;margin-top:4px;">Separate multiple with commas.</div>
                    </div>
                    <input type="hidden" asp-for="IsExportAll" value="true" />
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-download"></i> Export All Reports
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Export campaign-wise -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">
                <h6 class="card-header-title">
                    <i class="bi bi-megaphone-fill me-2" style="color:#22c55e;"></i>Single Campaign
                </h6>
            </div>
            <div class="card-body">
                <p style="font-size:0.82rem;color:#64748b;margin-bottom:16px;line-height:1.6;">
                    Export the delivery report for one specific campaign.
                </p>
                <form asp-action="Export" asp-controller="Campaigns" asp-area="Member" method="post">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <input type="checkbox" id="notifyWise" class="form-check-input" asp-for="IsSendEmailNotifyForCampaignwise"
                               style="border-color:#cbd5e1;border-radius:4px;cursor:pointer;" />
                        <label for="notifyWise" style="font-size:0.82rem;font-weight:500;color:#374151;cursor:pointer;">
                            Email me when the export is ready
                        </label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Campaign</label>
                        <select class="form-select" asp-for="Id"
                                asp-items="@(new SelectList(Model.CampaignSelectList, "Value", "Text"))">
                            <option value="">— Choose a campaign —</option>
                        </select>
                        <span asp-validation-for="Id" class="field-validation-error"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Notify email(s)</label>
                        <input type="text" class="form-control" asp-for="SendEmailAddress" value="@loggedInUserEmail"
                               placeholder="email@example.com" />
                    </div>
                    <input type="hidden" asp-for="IsExportAll" value="false" />
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-download"></i> Export Campaign Report
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
