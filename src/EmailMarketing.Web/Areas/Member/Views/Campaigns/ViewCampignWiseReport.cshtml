@model CampaignsModel
@{
    ViewData["Title"] = "Campaign Delivery Report";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Campaign Delivery Report</h1>
        <p class="page-subtitle">Contact-level send and open tracking</p>
    </div>
    <a asp-area="Member" asp-controller="Campaigns" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Campaign List
    </a>
</div>

<!-- Campaign info strip -->
<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-start">
            <div class="col-md-8">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Campaign</div>
                        <div style="font-size:0.9rem;font-weight:700;color:#0f172a;">@Model.CampaignName</div>
                    </div>
                    <div class="col-sm-6">
                        <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Sender</div>
                        <div style="font-size:0.875rem;font-weight:500;color:#374151;">@Model.SenderName <span style="color:#94a3b8;">(@Model.SenderEmail)</span></div>
                    </div>
                    <div class="col-sm-6">
                        <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Subject</div>
                        <div style="font-size:0.875rem;font-weight:500;color:#374151;">@Model.EmailSubject</div>
                    </div>
                    <div class="col-sm-6">
                        <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:4px;">Description</div>
                        <div style="font-size:0.875rem;color:#64748b;">@Model.Description</div>
                    </div>
                </div>
            </div>
            @if (Model.EmailTemplate != null)
            {
                <div class="col-md-4">
                    <div style="font-size:0.7rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:6px;">Email Template</div>
                    <div style="border:1px solid var(--border-color);border-radius:8px;overflow:hidden;position:relative;height:110px;background:#f8fafc;cursor:pointer;"
                         data-bs-toggle="modal" data-bs-target="#templatebody">
                        <div style="transform:scale(0.45);transform-origin:top left;width:222%;pointer-events:none;padding:6px;">
                            @Html.Raw(Model.EmailTemplate.EmailTemplateBody)
                        </div>
                        <div style="position:absolute;bottom:0;left:0;right:0;padding:6px 8px;background:rgba(13,17,23,0.75);display:flex;align-items:center;gap:6px;">
                            <span style="font-size:0.72rem;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1;">@Model.EmailTemplate.EmailTemplateName</span>
                            <i class="bi bi-eye" style="color:#818cf8;font-size:0.8rem;flex-shrink:0;"></i>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delivery table -->
<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <input type="hidden" id="campaignId" value="@Model.CampaignId" />
    <div class="table-responsive">
        <table class="table table-hover" id="campaign-table">
            <thead>
                <tr>
                    <th>Contact Email</th>
                    <th>Delivered</th>
                    <th>Opened</th>
                    <th>Opened At</th>
                    <th>Sent At</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Template preview modal -->
@if (Model.EmailTemplate != null)
{
    <div class="modal fade" id="templatebody" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title"><i class="bi bi-eye me-2 text-accent"></i>@Model.EmailTemplate.EmailTemplateName</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">@Html.Raw(Model.EmailTemplate.EmailTemplateBody)</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="~/js/ajax-call.js"></script>
    <script src="~/js/project/campaignreport.js"></script>
    <script>
        $(function () {
            var url = '@Url.Action("ViewDeleveryReport", "Campaigns", new { Area = "Member", campaignId = Model.CampaignId })';
            loadDatatable(url);
        });
    </script>
}
