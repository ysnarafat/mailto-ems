@model CampaignsModel
@{
    ViewData["Title"] = "Campaigns";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Campaigns</h1>
        <p class="page-subtitle">Manage and monitor your email campaigns</p>
    </div>
    <a asp-area="Member" asp-controller="Campaigns" asp-action="AddCampaign" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Campaign
    </a>
</div>

<div class="card">
    <partial name="_ActionMessage" model="@Model.Response" />
    <div class="table-responsive">
        <table class="table table-hover" id="campaign-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Group</th>
                    <th>Status</th>
                    <th>Contacts</th>
                    <th>Send Date</th>
                    <th class="text-center" style="width:100px;">Actions</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

<!-- Campaign activate/finish modal -->
<div id="modal-activeDraft" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-lightning-charge-fill text-warning me-2"></i><span id="activeDraftTitle">Finish Campaign</span></h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.875rem;">
                <p class="mb-0">Are you sure you want to <strong><span id="activeDraftSure">finish</span></strong> this campaign?</p>
                <form id="activeDraftForm" action="@Url.Action("ActivateCampaign", "Campaigns", new { Area = "Member" })" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="activeDraftId" name="id" />
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="activeButton" class="btn btn-primary btn-sm">
                    <span id="activeDraftButton">Confirm</span>
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script src="~/js/ajax-call.js"></script>
    <script src="~/js/project/campaign.js"></script>
    <script>
        $(function () {
            var url       = '@Url.Action("ViewCampaigns", "Campaigns", new { Area = "Member" })';
            var ReportUrl = '@Url.Action("ViewCampignWiseReport", "Campaigns", new { Area = "Member" })';
            loadDatatable(url, ReportUrl);

            $('#modal-activeDraft').on('show.bs.modal', function (e) {
                var id    = $(e.relatedTarget).attr('data-id');
                var title = $(e.relatedTarget).attr('data-title');
                $("#activeDraftId").val(id);
                var finishing = title !== 'Processing';
                $("#activeDraftTitle").text(finishing ? 'Finish Campaign' : 'Process Campaign');
                $("#activeDraftSure").text(finishing ? 'finish' : 'process');
                $("#activeDraftButton").text(finishing ? 'Finish' : 'Process');
            });

            $("#activeButton").click(function () { $("#activeDraftForm").submit(); });
        });
    </script>
}
