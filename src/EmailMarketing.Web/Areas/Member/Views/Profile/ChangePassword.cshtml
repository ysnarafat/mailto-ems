@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-header">
    <h1 class="page-title">Change Password</h1>
    <a asp-area="Member" asp-controller="Profile" asp-action="Index" class="btn btn-light">
        <i class="bi bi-arrow-left"></i> Back to Profile
    </a>
</div>

<div class="card" style="max-width:480px;">
    <div class="card-header">
        <h6 class="card-header-title"><i class="bi bi-key-fill me-2 text-accent"></i>Update Password</h6>
    </div>
    <div class="card-body">
        <partial name="_ActionMessage" model="@Model.Response" />
        <form asp-action="ChangePassword" asp-controller="Profile" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="alert alert-danger mb-3" style="font-size:0.82rem;padding:10px 14px;"></div>

            <div class="mb-3">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Current Password</label>
                <div style="position:relative;">
                    <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" id="cp" style="padding-right:40px;" />
                    <button type="button" onclick="toggleF('cp','i0')" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;" tabindex="-1">
                        <i class="bi bi-eye" id="i0"></i>
                    </button>
                </div>
                <span asp-validation-for="CurrentPassword" class="field-validation-error"></span>
            </div>

            <div class="mb-3">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">New Password</label>
                <div style="position:relative;">
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="At least 6 characters" id="np" style="padding-right:40px;" />
                    <button type="button" onclick="toggleF('np','i1')" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;" tabindex="-1">
                        <i class="bi bi-eye" id="i1"></i>
                    </button>
                </div>
                <div style="height:4px;background:#f1f5f9;border-radius:2px;overflow:hidden;margin-top:6px;">
                    <div id="pwdStrBar" style="height:100%;border-radius:2px;transition:width 0.3s,background 0.3s;width:0;background:#ef4444;"></div>
                </div>
                <span asp-validation-for="NewPassword" class="field-validation-error"></span>
            </div>

            <div class="mb-4">
                <label class="form-label" style="font-size:0.8rem;font-weight:600;color:#374151;">Confirm New Password</label>
                <div style="position:relative;">
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control" placeholder="Repeat new password" id="cnp" style="padding-right:40px;" />
                    <button type="button" onclick="toggleF('cnp','i2')" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;color:#94a3b8;cursor:pointer;" tabindex="-1">
                        <i class="bi bi-eye" id="i2"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmNewPassword" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-check-circle"></i> Update Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
    <script>
        function toggleF(id, iconId) {
            var el = document.getElementById(id), icon = document.getElementById(iconId);
            var show = el.type === 'password';
            el.type = show ? 'text' : 'password';
            icon.className = show ? 'bi bi-eye-slash' : 'bi bi-eye';
        }
        document.getElementById('np').addEventListener('input', function () {
            var v = this.value, bar = document.getElementById('pwdStrBar'), s = 0;
            if (v.length >= 6) s++; if (v.length >= 10) s++;
            if (/[A-Z]/.test(v)) s++; if (/[0-9]/.test(v)) s++; if (/[^A-Za-z0-9]/.test(v)) s++;
            var c = ['#ef4444','#f59e0b','#f59e0b','#22c55e','#22c55e'];
            var w = ['20%','40%','60%','80%','100%'];
            bar.style.width = v.length ? (w[s-1]||'20%') : '0';
            bar.style.background = v.length ? (c[s-1]||'#ef4444') : '#ef4444';
        });
    </script>
}
